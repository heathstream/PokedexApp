<?xml version="1.0" encoding="UTF-8" ?>
<ContentView
    x:Class="PokedexApp.Controls.ShimmerView"
    xmlns="http://schemas.microsoft.com/dotnet/maui/global"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:d="http://schemas.microsoft.com/dotnet/maui/global/design"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:Name="Root">
    
    <ContentView.Content>
        <BoxView x:Name="ShimmerBox" 
                 CornerRadius="{Binding CornerRadius, Source={x:Reference Root}}" 
                 WidthRequest="{Binding WidthRequest, Source={x:Reference Root}}" 
                 HeightRequest="{Binding HeightRequest, Source={x:Reference Root}}">
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="LightGray" Offset="-1.0"/>
                    <GradientStop Color="White" Offset="0.5"/>
                    <GradientStop Color="LightGray" Offset="2.0"/>
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>
    </ContentView.Content>
    
</ContentView>
