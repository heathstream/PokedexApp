<?xml version="1.0" encoding="UTF-8" ?>
<ContentView
    x:Class="PokedexApp.Controls.EvolutionCollectionView"
    xmlns="http://schemas.microsoft.com/dotnet/maui/global"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:d="http://schemas.microsoft.com/dotnet/maui/global/design"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:PokedexApp.Controls"
    mc:Ignorable="d">
    <ContentView.Content>
        <VerticalStackLayout BindableLayout.ItemsSource="{Binding .}" Spacing="5">
            <BindableLayout.ItemTemplate>
                <DataTemplate>
                    <Border StrokeShape="RoundRectangle 15">
                        <Grid RowDefinitions="*,Auto,Auto" Padding="15,10" HeightRequest="110">

                            <Image Source="{Binding Pokemon.Sprite}" Grid.RowSpan="3" HorizontalOptions="End" VerticalOptions="Center" Scale="2" Opacity="0.7"/>
                            
                            <Label TextColor="Black" Text="{Binding Details.MinLevel, StringFormat='At level {0}'}" FontSize="Body"
                                    Grid.Row="0" VerticalOptions="Start" HorizontalOptions="Start" IsVisible="{Binding Details.MinLevel, Converter={StaticResource PropertyNotEmptyConverter}}"/>
                            <Label TextColor="Black" Text="{Binding Details.Item.Name, StringFormat='By using a {0}'}" FontSize="Body"
                                    Grid.Row="0" VerticalOptions="Start" HorizontalOptions="Start" IsVisible="{Binding Details.Item, Converter={StaticResource PropertyNotEmptyConverter}}"/>
                            
                            <HorizontalStackLayout Grid.Row="1" Spacing="5">
                                <Label TextColor="Black" Text="{Binding Pokemon.Name}" FontSize="Large" FontAttributes="Bold" 
                                       Grid.Row="1" VerticalOptions="End" HorizontalOptions="Start"/>
                                <Label TextColor="Gray" Text="{Binding Pokemon.Id, StringFormat='#{0:000}'}" FontSize="Large" 
                                       Grid.Row="1" VerticalOptions="End" HorizontalOptions="Start"/>
                            </HorizontalStackLayout>

                            <HorizontalStackLayout Grid.Row="2" BindableLayout.ItemsSource="{Binding Pokemon.Types}" Spacing="5" Grid.ColumnSpan="2" HorizontalOptions="Start" VerticalOptions="Start">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <Border StrokeShape="RoundRectangle 20" Padding="10,0,10,2" BackgroundColor="{Binding ., Converter={StaticResource TypeColorConverter}}">
                                            <Label TextColor="White" Text="{Binding .}" FontSize="Small" FontAttributes="Bold" VerticalOptions="Center"/>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </HorizontalStackLayout>

                        </Grid>
                        
                    </Border>
                </DataTemplate>
            </BindableLayout.ItemTemplate>
        </VerticalStackLayout>
    </ContentView.Content>
</ContentView>
