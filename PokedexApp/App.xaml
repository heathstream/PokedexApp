<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:PokedexApp"
             xmlns:converters="clr-namespace:PokedexApp.Converters"
             x:Class="PokedexApp.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <converters:TypeColorConverter x:Key="TypeColorConverter"/>
            <converters:BaseStatColorConverter x:Key="BaseStatColorConverter"/>
            <converters:TypeIconConverter x:Key="TypeIconConverter"/>
            <converters:PropertyNotEmptyConverter x:Key="PropertyNotEmptyConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
