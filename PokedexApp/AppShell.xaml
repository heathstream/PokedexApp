<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="PokedexApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:PokedexApp"
    xmlns:views="clr-namespace:PokedexApp.Views"
    Title="PokedexApp"
    TabBarBackgroundColor="#dc0a2d"
    TabBarTitleColor="White"
    TabBarForegroundColor="White"
    TabBarUnselectedColor="#f6c2ca">

    <TabBar>
        <Tab Title="Pokémon" Icon="dog.png">
            <ShellContent Title="Pokémon" 
                          ContentTemplate="{DataTemplate local:MainPage}" 
                          Route="MainPage"/>
        </Tab>
        <Tab Title="Types" Icon="leaf.png">
            <ShellContent Title="Types" 
                          ContentTemplate="{DataTemplate views:TypesPage}"
                          Route="TypesPage"/>
        </Tab>
        <Tab Title="Moves" Icon="explosion.png">
            <ShellContent Title="Moves" 
                          ContentTemplate="{DataTemplate views:MoveSearchPage}"
                          Route="MoveSearchPage"/>
        </Tab>
        <Tab Title="Items" Icon="water_spray.png">
            <ShellContent Title="Items" 
                          ContentTemplate="{DataTemplate views:ItemSearchPage}"
                          Route="ItemSearchPage"/>
        </Tab>
    </TabBar>
    
</Shell>
