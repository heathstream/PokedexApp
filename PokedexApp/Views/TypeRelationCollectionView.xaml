<?xml version="1.0" encoding="UTF-8" ?>
<ContentView
    x:Class="PokedexApp.Views.TypeRelationCollectionView"
    xmlns="http://schemas.microsoft.com/dotnet/maui/global"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:d="http://schemas.microsoft.com/dotnet/maui/global/design"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:PokedexApp.Views"
    xmlns:models="clr-namespace:PokedexApp.Models"
    mc:Ignorable="d">
    <ContentView.Content>
        <CollectionView ItemsSource="{Binding .}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid RowDefinitions="*,5">
                        <Border StrokeShape="RoundRectangle 20" Padding="15,3,15,5" WidthRequest="140" BackgroundColor="{Binding Key, Converter={StaticResource TypeColorConverter}}">
                            <Grid ColumnDefinitions="Auto,*">
                                <Label Grid.Column="0" TextColor="White" Text="{Binding Key}" FontSize="Small" FontAttributes="Bold" VerticalOptions="Center"/>
                                <Label Grid.Column="1" TextColor="White" Text="{Binding Value, StringFormat='{0:F2}'}" FontSize="Body" FontAttributes="Bold" VerticalOptions="Center" HorizontalOptions="End"/>
                            </Grid>
                        </Border>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </ContentView.Content>

    <ContentView.Resources>
        <ResourceDictionary>
            <models:TypeColorConverter x:Key="TypeColorConverter"/>
        </ResourceDictionary>
    </ContentView.Resources>
    
</ContentView>
