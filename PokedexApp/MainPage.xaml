<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:PokedexApp.Views"
             x:Class="PokedexApp.MainPage"
             HeightRequest="2000"
             x:Name="contentPage">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#d30b41" Offset="0.1"/>
            <!--<GradientStop Color="#8d072b" Offset="1.0"/>-->
        </LinearGradientBrush>
    </ContentPage.Background>


    <Grid>
        <ScrollView>

            <Grid RowSpacing="10" RowDefinitions="110,Auto,*" Padding="40">

                <!--ENTRY BOX & SEARCH BUTTON-->
                <Border Grid.Row="0" StrokeShape="RoundRectangle 30" StrokeThickness="0" VerticalOptions="End">
                    <Entry TextColor="Black" FontSize="Medium" BackgroundColor="White" TextChanged="Entry_TextChanged" ClearButtonVisibility="WhileEditing" HeightRequest="60"/>
                </Border>

                <!--SEARCH RESULTS LIST-->
                <Border Grid.Row="2" Grid.Column="1" StrokeShape="RoundRectangle 30" StrokeThickness="0">
                    <ScrollView>
                        <CollectionView x:Name="pokemonList" BackgroundColor="AntiqueWhite" SelectionMode="Single" ItemsSource="{Binding FilteredPokemonList}" SelectionChanged="pokemonList_SelectionChanged">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="Auto,*" Padding="10,5" ColumnSpacing="15">
                                        <Image Grid.Column="0" Source="{Binding Sprite}" WidthRequest="50"/>
                                        <Grid Grid.Column="1" RowDefinitions="Auto,Auto">
                                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="5">
                                                <Label TextColor="Black" FontAttributes="Bold" Text="{Binding Name}" FontSize="Medium"/>
                                                <Label TextColor="Gray" FontAttributes="Bold" Text="{Binding Id, StringFormat='#{0:000}'}" FontSize="Small" Grid.Column="1" VerticalOptions="Center"/>
                                            </Grid>
                                            <Label TextColor="Black" Text="{Binding Name}" Grid.Row="1"/>
                                        </Grid>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </ScrollView>
                </Border>
            </Grid>

        </ScrollView>

        <views:PokedexFrameView ScaleX="-1" />

    </Grid>

</ContentPage>
